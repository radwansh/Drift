{
  "name": "saas-salary-compare",
  "version": "1.0.0",
  "private": true,
  "description": "Multi-tenant SAAS for payroll salary comparison between periods",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "db:generate": "pnpm --filter @saas/db db:generate",
    "db:migrate": "pnpm --filter @saas/db db:migrate",
    "db:seed": "pnpm --filter @saas/db db:seed"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "prettier": "^3.5.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@11.8.0"
}
